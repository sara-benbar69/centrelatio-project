# PostgreSQL connection
DATABASE_URL="postgresql://user:password@localhost:5432/centrelatio?schema=public"

# JWT configuration
JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="7d"

# Admin initial credentials (seed only)
ADMIN_EMAIL="admin@centrelatio.com"
ADMIN_PASSWORD="ChangeMe123!"

# Google Sheets backup (optional)
GOOGLE_SPREADSHEET_ID=""
GOOGLE_APPLICATION_CREDENTIALS="./server/credentials.json"

# Nodemailer SMTP configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASSWORD="securepassword"
SMTP_FROM="Centrelatio <no-reply@centrelatio.com>"

# Analytics
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173"
